# Conexión a PostgreSQL (Neon, Supabase, etc.)
DATABASE_URL="postgres://usuario:password@host/orchaix?sslmode=require"

# API key de Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=""

# Secreto para firmar los JWT de sesión. Obligatorio en producción.
# Genera uno con: openssl rand -base64 32
JWT_SECRET=""

# URL pública de la app (usada para registrar webhooks de Telegram)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Tope diario de mensajes por agente (opcional, por defecto 500)
MAX_MESSAGES_PER_AGENT_PER_DAY="500"
